# This file specifies files that are *not* uploaded to Google Cloud
# using gcloud. It follows the same syntax as .gitignore, with the addition of
# "#!include" directives (which insert the entries of the given .gitignore-style
# file at that point).
#
# For more information, run:
#   $ gcloud topic gcloudignore
#
.gcloudignore
.git
.gitignore
.github/

# Python pycache:
__pycache__/
*.pyc
*.pyo
*.pyd
.Python

# Ignored by the build system
/setup.cfg

# Node modules
/node_modules
npm-debug.log
package-lock.json

# Python virtual env
/.venv
/venv
/env

# iOS - not needed on backend
/ios

# Development
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Testing
.coverage
htmlcov/
.pytest_cache/
.tox/

# Documentation (except README)
*.md
!README.md
DEPLOYMENT.md

# Storybook - already built
storybook-static/
.storybook/

# TypeScript source - already compiled to static/index.js
/src
/spec
/tests
tsconfig.json
lit-localize.json

# Build artifacts
.esbuild/

# Development dependencies
requirements-dev.txt
